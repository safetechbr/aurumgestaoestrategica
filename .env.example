# Copie este arquivo para ".env" e preencha com seus valores reais.
# NUNCA suba o arquivo ".env" para o Git (ele já está no .gitignore).

# String de conexão do Postgres.
# Se usar Supabase ou Neon, pegue essa URL no painel do projeto (Connection string).
DATABASE_URL="postgresql://usuario:senha@host:5432/nome_do_banco"

# Chave da API da Anthropic, usada na categorização por IA (fallback).
# Gere em https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY="sk-ant-..."
